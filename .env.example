# =============================================================
# GALACTICA LENDING BOT — ENVIRONMENT CONFIGURATION EXAMPLE
# =============================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
# =============================================================

# ── APPLICATION ───────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com
DEMO_MODE=false
NEXT_PUBLIC_ETH_ADDRESS_SHORT=0x742d35...f0bEb
NEXT_PUBLIC_ETH_ADDRESS_FULL=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb

# ── AGENT WALLET (WDK Self-Custodial) ─────────────────────────
AGENT_WALLET_PRIVATE_KEY=your_wif_private_key_here
AGENT_WALLET_ADDRESS=your_btc_address_here
AGENT_TREASURY_USDT=100000
AGENT_TREASURY_XAUT=25
AGENT_TREASURY_BTC=5.5

# ── ETH WITHDRAWAL ADDRESS ────────────────────────────────────
AGENT_ETH_WITHDRAW_ADDRESS=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb

# ── COLLATERAL ESCROW ─────────────────────────────────────────
COLLATERAL_CONTRACT_ADDRESS=0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599

# ── COLLATERAL REQUIREMENTS ───────────────────────────────────
COLLATERAL_REQUIREMENT_PERCENT=150
COLLATERAL_MIN_USD=100

# ── WDK CONFIGURATION ─────────────────────────────────────────
WDK_SEED_PHRASE=your_seed_phrase_here
WDK_NETWORK=mainnet
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
WDK_ETH_MAX_FEE=500000000000000

# ── TOKEN CONTRACTS ───────────────────────────────────────────
USDT_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D831ec7
XAUT_CONTRACT=0x68749665FF8D2d112Fa859AA293F07A622782F38

# ── INTERCOM PROTOCOL ─────────────────────────────────────────
INTERCOM_INDEXER_URL=https://api.trac.network/v1
INTERCOM_API_KEY=your_intercom_api_key_here
INTERCOM_AGENT_ID=galactica-lending-bot-v1.0.0
INTERCOM_BROADCAST_CHANNEL=lending-market-signals

# ── OPENAI CONFIGURATION ──────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.3

# ── NETWORK ENDPOINTS ─────────────────────────────────────────
BTC_NETWORK=mainnet
BTC_RPC_URL=https://mempool.space/api
BTC_EXPLORER_URL=https://mempool.space
ETH_EXPLORER_URL=https://etherscan.io

# ── YIELD OPTIMIZATION ────────────────────────────────────────
AAVE_POOL_ADDRESS_PROVIDER=0x2f39d218133AFaB8F2B819B1066c7E434Ad94E9e
YIELD_POOL_ADDRESS=0x87870Bcd3b5Fd43f9d7b9a7F1C8E3d0E9C8F3E2D
YIELD_MIN_APY=3.5
AAVE_ESTIMATED_APY=4.25

# ── DATABASE ──────────────────────────────────────────────────
DB_PATH=./data/loans.json
BLACKLIST_PATH=./data/blacklist.json

# ── LOGGING ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/agent.log

# ── SECURITY ──────────────────────────────────────────────────
JWT_SECRET=your-secure-jwt-secret-here
API_RATE_LIMIT=100

# ── NOTIFICATIONS ─────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# ── BACKUP ────────────────────────────────────────────────────
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BLACKLIST_PATH=./data/blacklist.json

# ── AGENT LOOP CONFIGURATION ──────────────────────────────────
AGENT_SCAN_INTERVAL_MINUTES=5
AGENT_LIQUIDITY_THRESHOLD_USDT=1000
AGENT_MAX_LOAN_USDT=5000
AGENT_MIN_LOAN_USDT=100
AGENT_YIELD_THRESHOLD=1000
REPAYMENT_GRACE_DAYS=3
LOAN_LIQUIDATION_LTV=0.85

# ── YIELD PROTOCOL ────────────────────────────────────────────
YIELD_PROTOCOL_URL=https://api.tether.io/yield/v1
YIELD_POOL_ADDRESS=0xYieldPoolAddressHere
YIELD_MIN_APY=3.5

# ── SECURITY ──────────────────────────────────────────────────
AUTH_CHALLENGE_EXPIRY_SECONDS=300
JWT_SECRET=your_jwt_secret_here_min_32_chars
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── DEMO MODE (for hackathon simulation) ──────────────────────
DEMO_MODE=true
DEMO_BTC_ADDRESS=bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh
DEMO_BTC_BALANCE=2.5
DEMO_TX_COUNT=1420
