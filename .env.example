# =============================================================
# GALACTICA LENDING BOT — ENVIRONMENT CONFIGURATION
# =============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================

# ── APPLICATION ───────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AGENT WALLET (WDK Self-Custodial) ─────────────────────────
# The lending agent's private key (WIF format or hex) — kept server-side only
AGENT_WALLET_PRIVATE_KEY=your_wif_private_key_here
AGENT_WALLET_ADDRESS=your_btc_address_here
AGENT_TREASURY_USDT=50000
AGENT_TREASURY_XAUT=10

# ── WDK (Wallet Dev Kit — Tether) ─────────────────────────────
# WDK API endpoint and credentials
WDK_API_URL=https://wdk.tether.io/api/v1
WDK_API_KEY=your_wdk_api_key_here
WDK_API_SECRET=your_wdk_api_secret_here
WDK_NETWORK=mainnet

# USDT Contract address (Ethereum / Tron / Liquid)
USDT_CONTRACT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
XAUT_CONTRACT_ADDRESS=0x68749665FF8D2d112Fa859AA293F07A622782F38

# ── INTERCOM PROTOCOL (Trac Systems) ─────────────────────────
# Trac Indexer endpoint for BTC/TAP on-chain data
INTERCOM_INDEXER_URL=https://indexer.trac.network
INTERCOM_SC_BRIDGE_URL=ws://localhost:9021
INTERCOM_API_KEY=your_intercom_api_key_here
INTERCOM_AGENT_ID=galactica-lending-bot-v1
INTERCOM_BROADCAST_CHANNEL=lending-signals

# ── OPENAI / LLM (OpenClaw Negotiation Engine) ────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# ── BITCOIN NETWORK ───────────────────────────────────────────
BTC_NETWORK=mainnet
BTC_RPC_URL=https://blockstream.info/api
BTC_EXPLORER_URL=https://mempool.space

# ── DATABASE (LocalStore / SQLite) ────────────────────────────
DB_PATH=./data/loans.json
BLACKLIST_PATH=./data/blacklist.json

# ── AGENT LOOP CONFIGURATION ──────────────────────────────────
AGENT_SCAN_INTERVAL_MINUTES=5
AGENT_LIQUIDITY_THRESHOLD_USDT=1000
AGENT_MAX_LOAN_USDT=5000
AGENT_MIN_LOAN_USDT=100
AGENT_YIELD_THRESHOLD=1000
REPAYMENT_GRACE_DAYS=3
LOAN_LIQUIDATION_LTV=0.85

# ── YIELD PROTOCOL ────────────────────────────────────────────
YIELD_PROTOCOL_URL=https://api.tether.io/yield/v1
YIELD_POOL_ADDRESS=0xYieldPoolAddressHere
YIELD_MIN_APY=3.5

# ── SECURITY ──────────────────────────────────────────────────
AUTH_CHALLENGE_EXPIRY_SECONDS=300
JWT_SECRET=your_jwt_secret_here_min_32_chars
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── DEMO MODE (for hackathon simulation) ──────────────────────
DEMO_MODE=true
DEMO_BTC_ADDRESS=bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh
DEMO_BTC_BALANCE=2.5
DEMO_TX_COUNT=1420
